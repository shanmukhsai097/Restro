NODE_VERSION=20
NODE_ENV=production
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=12h
DATABASE_URL=postgresql://postgres.PROJECTREF:YOUR_PASSWORD@REAL_POOLER_HOST:6543/postgres
OCR_ENABLED=true
# Optional. Leave blank on Render if frontend and backend use same origin.
# FRONTEND_URL=https://your-render-service.onrender.com
